{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aelitium.dev/schemas/decision_case.v1.schema.json",
  "title": "DecisionCase v1",
  "description": "Identity, document inventory, lifecycle state, and timestamps for a verifiable decision case.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "decision-case/v1"
    },
    "case_id": {
      "type": "string",
      "pattern": "^case-[a-z0-9][a-z0-9-]{2,63}$"
    },
    "decision_domain": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,63}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "case_version": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "enum": [
        "DRAFT",
        "ASSESSMENT_PENDING",
        "NEEDS_MORE_EVIDENCE",
        "HUMAN_REVIEW",
        "READY_FOR_APPROVAL",
        "HUMAN_APPROVAL_REQUIRED",
        "APPROVED",
        "REJECTED",
        "RECEIPT_ISSUED"
      ]
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/document"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "schema_version",
    "case_id",
    "decision_domain",
    "title",
    "case_version",
    "state",
    "documents",
    "created_at",
    "updated_at"
  ],
  "$defs": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
        },
        "document_type": {
          "enum": [
            "commercial_proposal",
            "internal_policy",
            "security_questionnaire",
            "executed_dpa",
            "vendor_assurance_letter",
            "other"
          ]
        },
        "filename": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "media_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "version": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,31}$"
        },
        "added_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "document_id",
        "document_type",
        "filename",
        "media_type",
        "sha256",
        "version",
        "added_at"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
