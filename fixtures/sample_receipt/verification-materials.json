  "policy_pack": {
    "confidence_floor": 70,
    "decision_domain": "ai_vendor_approval",
    "description": "Deterministic minimum controls for the fictional Nerythica AI vendor approval workflow.",
    "policy_schema_version": "aelitium-policy/v1",
    "policy_version": "ai-vendor-approval/1.1.0",
    "routing_precedence": [
      {
        "condition": "blocking_controls_not_empty",
        "priority": 1,
        "selected_approval_role": null,
        "state": "NEEDS_MORE_EVIDENCE"
      },
      {
        "condition": "director_approval_required",
        "priority": 2,
        "selected_approval_role": "director",
        "state": "HUMAN_APPROVAL_REQUIRED"
      },
      {
        "condition": "human_review_required",
        "priority": 3,
        "selected_approval_role": "operations_reviewer",
        "state": "HUMAN_REVIEW"
      },
      {
        "condition": "otherwise",
        "priority": 4,
        "selected_approval_role": "operations_reviewer",
        "state": "READY_FOR_APPROVAL"
      }
    ],
    "rules": [
      {
        "blocking": false,
        "control_id": "R1_PRICE_CEILING",
        "description": "Annual recurring cost above EUR 15,000 requires director approval.",
        "expected_value": 15000,
        "fact_key": "commercial.annual_price_eur",
        "failure_effect": "REQUIRE_DIRECTOR_APPROVAL",
        "missing_evidence": "Current written annual recurring price",
        "missing_fact_result": "FAIL",
        "operator": "fact_integer_at_most",
        "suggested_request": "Provide the current written offer showing annual recurring cost and all mandatory charges.",
        "version": "1.0.0"
      },
      {
        "blocking": true,
        "control_id": "R2_EU_DATA_RESIDENCY",
        "description": "Customer Data and backups require written EU or EEA-only confirmation.",
        "expected_value": true,
        "fact_key": "privacy.eu_eea_only_residency_confirmed",
        "failure_effect": "BLOCK_APPROVAL",
        "missing_evidence": "Written confirmation covering Customer Content, backups, and core processing in the EU or EEA",
        "missing_fact_result": "FAIL",
        "operator": "fact_boolean_equals",
        "suggested_request": "Confirm in writing that Customer Content, backups, and core processing for this tenant will remain in the EU or EEA.",
        "version": "1.0.0"
      },
      {
        "blocking": true,
        "control_id": "R3_DPA_SIGNED",
        "description": "A DPA executed by both parties is required before Customer Data is uploaded.",
        "expected_value": true,
        "fact_key": "privacy.dpa_executed_by_both_parties",
        "failure_effect": "BLOCK_APPROVAL",
        "missing_evidence": "DPA execution evidence for both parties",
        "missing_fact_result": "FAIL",
        "operator": "fact_boolean_equals",
        "suggested_request": "Provide a Data Processing Addendum executed by authorized representatives of both parties.",
        "version": "1.0.0"
      },
      {
        "blocking": true,
        "control_id": "R4_CERTIFICATION",
        "description": "SOC 2 Type II or equivalent assurance must be issued; planned or in-progress status is insufficient.",
        "expected_value": true,
        "fact_key": "security.assurance_report_issued",
        "failure_effect": "REQUEST_EVIDENCE",
        "missing_evidence": "Issued SOC 2 Type II report or documented equivalent assurance",
        "missing_fact_result": "FAIL",
        "operator": "fact_boolean_equals",
        "suggested_request": "Provide the issued SOC 2 Type II report, a dated issuance confirmation, or documented equivalent assurance.",
        "version": "1.0.0"
      },
      {
        "blocking": false,
        "control_id": "R5_CONFLICT_GATE",
        "description": "Any material conflict in the assessment requires human review.",
        "expected_value": 0,
        "fact_key": "assessment.conflicts_count",
        "failure_effect": "REQUIRE_HUMAN_REVIEW",
        "missing_evidence": "Resolution or acknowledgement of each material document conflict",
        "missing_fact_result": "FAIL",
        "operator": "assessment_conflicts_count_equals",
        "suggested_request": "Resolve or explicitly acknowledge the conflicting vendor statements before the final decision.",
        "version": "1.0.0"
      },
      {
        "blocking": false,
        "control_id": "R6_CONFIDENCE_FLOOR",
        "description": "Assessment confidence below 70 percent requires human review.",
        "expected_value": 70,
        "fact_key": "assessment.confidence",
        "failure_effect": "REQUIRE_HUMAN_REVIEW",
        "missing_evidence": "Higher-confidence evidence or explicit human assessment of uncertainty",
        "missing_fact_result": "FAIL",
        "operator": "assessment_confidence_at_least",
        "suggested_request": "Review the low-confidence findings and obtain additional evidence where material.",
        "version": "1.0.0"
      }
    ]
  },
