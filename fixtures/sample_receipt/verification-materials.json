{
  "assessment_schema": {
    "$defs": {
      "conflict": {
        "additionalProperties": false,
        "properties": {
          "conflict_id": {
            "pattern": "^conflict-[a-z0-9][a-z0-9-]{0,63}$",
            "type": "string"
          },
          "evidence_refs": {
            "items": {
              "$ref": "#/$defs/evidenceReference"
            },
            "maxItems": 20,
            "minItems": 2,
            "type": "array"
          },
          "requires_resolution": {
            "type": "boolean"
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "summary": {
            "maxLength": 2000,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "conflict_id",
          "summary",
          "severity",
          "requires_resolution",
          "evidence_refs"
        ],
        "type": "object"
      },
      "evidenceReference": {
        "additionalProperties": false,
        "properties": {
          "document_id": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$",
            "type": "string"
          },
          "locator": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "quoted_text": {
            "maxLength": 4000,
            "minLength": 1,
            "type": "string"
          },
          "reference_level": {
            "enum": [
              "source_reference",
              "validated_reference",
              "decision_evidence"
            ]
          }
        },
        "required": [
          "document_id",
          "locator",
          "quoted_text",
          "reference_level"
        ],
        "type": "object"
      },
      "fact": {
        "additionalProperties": false,
        "properties": {
          "evidence_refs": {
            "items": {
              "$ref": "#/$defs/evidenceReference"
            },
            "maxItems": 20,
            "minItems": 1,
            "type": "array"
          },
          "fact_id": {
            "pattern": "^fact-[a-z0-9][a-z0-9-]{0,63}$",
            "type": "string"
          },
          "fact_key": {
            "pattern": "^[a-z][a-z0-9_.]{2,127}$",
            "type": "string"
          },
          "statement": {
            "maxLength": 2000,
            "minLength": 1,
            "type": "string"
          },
          "value": {
            "$ref": "#/$defs/typedValue"
          }
        },
        "required": [
          "fact_id",
          "fact_key",
          "statement",
          "value",
          "evidence_refs"
        ],
        "type": "object"
      },
      "missingEvidence": {
        "additionalProperties": false,
        "properties": {
          "blocking": {
            "type": "boolean"
          },
          "control_hint": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$",
            "type": "string"
          },
          "description": {
            "maxLength": 2000,
            "minLength": 1,
            "type": "string"
          },
          "item_id": {
            "pattern": "^missing-[a-z0-9][a-z0-9-]{0,63}$",
            "type": "string"
          },
          "requested_evidence": {
            "maxLength": 2000,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "item_id",
          "control_hint",
          "description",
          "requested_evidence",
          "blocking"
        ],
        "type": "object"
      },
      "option": {
        "additionalProperties": false,
        "properties": {
          "benefits": {
            "items": {
              "maxLength": 500,
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "description": {
            "maxLength": 2000,
            "minLength": 1,
            "type": "string"
          },
          "label": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "option_id": {
            "pattern": "^option-[a-z0-9][a-z0-9-]{0,63}$",
            "type": "string"
          },
          "preconditions": {
            "items": {
              "maxLength": 500,
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "risks": {
            "items": {
              "maxLength": 500,
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "option_id",
          "label",
          "description",
          "benefits",
          "risks",
          "preconditions"
        ],
        "type": "object"
      },
      "recommendation": {
        "additionalProperties": false,
        "properties": {
          "conditions": {
            "items": {
              "maxLength": 500,
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "option_id": {
            "pattern": "^option-[a-z0-9][a-z0-9-]{0,63}$",
            "type": "string"
          },
          "rationale": {
            "maxLength": 3000,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "option_id",
          "rationale",
          "conditions"
        ],
        "type": "object"
      },
      "risk": {
        "additionalProperties": false,
        "properties": {
          "category": {
            "pattern": "^[a-z][a-z0-9_]{1,63}$",
            "type": "string"
          },
          "evidence_refs": {
            "items": {
              "$ref": "#/$defs/evidenceReference"
            },
            "maxItems": 20,
            "type": "array"
          },
          "likelihood": {
            "enum": [
              "unlikely",
              "possible",
              "likely",
              "unknown"
            ]
          },
          "risk_id": {
            "pattern": "^risk-[a-z0-9][a-z0-9-]{0,63}$",
            "type": "string"
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "summary": {
            "maxLength": 2000,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "risk_id",
          "category",
          "summary",
          "severity",
          "likelihood",
          "evidence_refs"
        ],
        "type": "object"
      },
      "typedValue": {
        "additionalProperties": false,
        "properties": {
          "boolean_value": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "integer_value": {
            "type": [
              "integer",
              "null"
            ]
          },
          "string_value": {
            "type": [
              "string",
              "null"
            ]
          },
          "value_type": {
            "enum": [
              "string",
              "integer",
              "boolean",
              "unknown"
            ]
          }
        },
        "required": [
          "value_type",
          "string_value",
          "integer_value",
          "boolean_value"
        ],
        "type": "object"
      }
    },
    "$id": "https://aelitium.dev/schemas/model_assessment.v1.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "description": "Strict structured assessment contract used by GPT-generated LIVE artifacts and deterministic precomputed DEMO fixtures; every instance is revalidated by the backend.",
    "properties": {
      "case_summary": {
        "maxLength": 4000,
        "minLength": 1,
        "type": "string"
      },
      "confidence": {
        "description": "Integer percentage; floats are prohibited by ADR-001.",
        "maximum": 100,
        "minimum": 0,
        "type": "integer"
      },
      "conflicts": {
        "items": {
          "$ref": "#/$defs/conflict"
        },
        "maxItems": 50,
        "type": "array"
      },
      "facts": {
        "items": {
          "$ref": "#/$defs/fact"
        },
        "maxItems": 100,
        "type": "array"
      },
      "missing_evidence": {
        "items": {
          "$ref": "#/$defs/missingEvidence"
        },
        "maxItems": 50,
        "type": "array"
      },
      "model": {
        "maxLength": 100,
        "minLength": 1,
        "type": "string"
      },
      "options": {
        "items": {
          "$ref": "#/$defs/option"
        },
        "maxItems": 10,
        "minItems": 1,
        "type": "array"
      },
      "prompt_version": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,63}$",
        "type": "string"
      },
      "recommendation": {
        "$ref": "#/$defs/recommendation"
      },
      "requires_human_review": {
        "type": "boolean"
      },
      "risks": {
        "items": {
          "$ref": "#/$defs/risk"
        },
        "maxItems": 50,
        "type": "array"
      },
      "schema_version": {
        "const": "model-assessment/v1"
      }
    },
    "required": [
      "schema_version",
      "model",
      "prompt_version",
      "case_summary",
      "facts",
      "conflicts",
      "missing_evidence",
      "risks",
      "options",
      "recommendation",
      "confidence",
      "requires_human_review"
    ],
    "title": "ModelAssessment v1",
    "type": "object"
  },
